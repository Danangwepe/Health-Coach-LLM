# ============================================================
#  .gitignore — AI Health Coach (React + FastAPI)
#  Letakkan file ini di ROOT folder project
#  (sejajar dengan folder backend/ dan frontend/)
# ============================================================


# ── ENVIRONMENT VARIABLES (PALING PENTING!) ─────────────────
# Jangan PERNAH commit file ini — berisi API keys!
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env
frontend/.env.local


# ── PYTHON ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
.venv/
ENV/

# Distribusi / build Python
dist/
build/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/


# ── NODE / REACT ─────────────────────────────────────────────
# Dependencies (diinstall ulang dengan npm install)
frontend/node_modules/

# Build output (dibuat ulang dengan npm run build)
frontend/dist/
frontend/build/

# Cache Vite
frontend/.vite/


# ── IDE / EDITOR ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
.project
.classpath


# ── SISTEM OPERASI ───────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~


# ── LOG FILES ────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── MISC ─────────────────────────────────────────────────────
*.zip
*.tar.gz
.temp/
.tmp/